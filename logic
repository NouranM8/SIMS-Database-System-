def calculate_and_save_gpa(conn, student_id, year_id):
    rows = _q(conn, """
        SELECT g.mark
        FROM Grades g
        JOIN Subject  sub ON g.subject_id =sub.subject_id
        JOIN Semester sem ON g.semester_id=sem.semester_id
        WHERE g.student_id=%s AND sem.school_year_id=%s
          AND sub.name!='Physical Education' AND g.mark IS NOT NULL
    """, (student_id, year_id))
    if not rows: return None
    avg = sum(float(r["mark"]) for r in rows) / len(rows)
    gpa = round(avg / 25, 2)
    if _q(conn, "SELECT gpa_id FROM GPA WHERE student_id=%s AND school_year_id=%s",
          (student_id, year_id), one=True):
        _run(conn, "UPDATE GPA SET value=%s WHERE student_id=%s AND school_year_id=%s",
             (gpa, student_id, year_id))
    else:
        _run(conn, "INSERT INTO GPA (student_id,school_year_id,value) VALUES (%s,%s,%s)",
             (student_id, year_id, gpa))
    return gpa

def get_gpa(conn, student_id, year_id=None):
    if year_id:
        return _q(conn, "SELECT value,student_rank FROM GPA WHERE student_id=%s AND school_year_id=%s",
                  (student_id, year_id), one=True)
    return _q(conn, """
        SELECT g.value, g.student_rank, a.year_name FROM GPA g
        JOIN AcademicYear a ON g.school_year_id=a.school_year_id
        WHERE g.student_id=%s ORDER BY g.school_year_id DESC LIMIT 1
    """, (student_id,), one=True)


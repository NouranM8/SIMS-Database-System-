def login(conn, username, password):
    return _q(conn, """
        SELECT user_id, user_name, role, student_id, teacher_id
        FROM User WHERE user_name=%s AND password=%s
    """, (username, _hash(password)), one=True)

def change_password(conn, user_id, old_pw, new_pw):
    u = _q(conn, "SELECT password FROM User WHERE user_id=%s", (user_id,), one=True)
    if not u or u["password"] != _hash(old_pw):
        return False, "Current password is incorrect."
    _run(conn, "UPDATE User SET password=%s, plain_password=%s WHERE user_id=%s",
         (_hash(new_pw), new_pw, user_id))
    return True, "Password changed."


"""
logic.py — SIMS complete database logic
Grade weights: quiz1(10) + quiz2(10) + midterm(20) + final(60) = 100 total
Pass threshold: 60 / 100 PER SUBJECT (not average)
Active semester: always the latest one in the DB
Promotion: per-subject pass/fail, missing finals block processing
"""

import hashlib, random, string
import mysql.connector


def get_announcements_for_user(conn, user_id, role,
                                student_id=None, teacher_id=None, class_id=None):
    conditions = []; params = []
    if role == "admin":
        conditions = ["1=1"]
    elif role == "teacher":
        conditions = ["a.target_type='all'", "a.target_type='teachers'"]
        if teacher_id:
            conditions.append("(a.target_type='teacher' AND a.target_id=%s)")
            params.append(teacher_id)
    else:
        conditions = ["a.target_type='all'", "a.target_type='students'"]
        if student_id:
            conditions.append("(a.target_type='student' AND a.target_id=%s)")
            params.append(student_id)
        if class_id:
            conditions.append("(a.target_type='class' AND a.target_id=%s)")
            params.append(class_id)
    where = " OR ".join(conditions) if conditions else "1=0"
    return _q(conn, f"""
        SELECT a.announcement_id, a.title, a.body,
               a.target_type, a.target_id, a.created_at,
               u.user_name AS sender,
               MAX(CASE WHEN ar.user_id=%s THEN 1 ELSE 0 END) AS is_read
        FROM Announcement a
        JOIN User u ON a.sender_id=u.user_id
        LEFT JOIN AnnouncementRead ar ON ar.announcement_id=a.announcement_id
        WHERE {where}
        GROUP BY a.announcement_id ORDER BY a.created_at DESC
    """, tuple([user_id] + params))


def check_finals_complete(conn, year_id):
    """
    Returns dict with counts:
      - missing_any:  students with no GradeDetail at all for any subject
      - pending_final: students who have GradeDetail but final_exam IS NULL
      - total_issues: sum of above
    Promotion should only proceed when total_issues == 0.
    """
    sems = _q(conn, "SELECT semester_id FROM Semester WHERE school_year_id=%s", (year_id,))
    if not sems:
        return {"missing_any": 0, "pending_final": 0, "total_issues": 0, "sem_ids": []}
    sem_ids = [s["semester_id"] for s in sems]
    ph = ",".join(["%s"] * len(sem_ids))

    # Students enrolled in a subject this year but have NO GradeDetail row at all
    missing = _q(conn, f"""
        SELECT COUNT(DISTINCT e.student_id) AS n
        FROM Enrollment e
        JOIN Subject sub ON e.subject_id = sub.subject_id
        JOIN Student s ON e.student_id = s.student_id
        WHERE sub.semester_id IN ({ph})
          AND s.status = 'active'
          AND sub.name != 'Physical Education'
          AND NOT EXISTS (
              SELECT 1 FROM GradeDetail gd
              WHERE gd.student_id = e.student_id
                AND gd.subject_id = sub.subject_id
                AND gd.semester_id = sub.semester_id
          )
    """, tuple(sem_ids), one=True)

    # Students who have GradeDetail but final_exam is NULL
    pending = _q(conn, f"""
        SELECT COUNT(DISTINCT gd.student_id) AS n
        FROM GradeDetail gd
        JOIN Student s ON gd.student_id = s.student_id
        WHERE gd.semester_id IN ({ph})
          AND gd.final_exam IS NULL
          AND s.status = 'active'
    """, tuple(sem_ids), one=True)

    m = missing["n"] if missing else 0
    p = pending["n"] if pending else 0
    return {
        "missing_any":   m,
        "pending_final": p,
        "total_issues":  m + p,
        "sem_ids":       sem_ids,
    }
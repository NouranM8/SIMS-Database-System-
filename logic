def get_dashboard_stats(conn):
    sem = get_active_semester(conn)
    sem_id = sem["semester_id"] if sem else 0

    stats = {
        "active_semester":  sem,
        "total_students":   _q(conn, "SELECT COUNT(*) AS n FROM Student WHERE status='active'", one=True)["n"],
        "total_teachers":   _q(conn, "SELECT COUNT(*) AS n FROM Teacher", one=True)["n"],
        "total_classes":    _q(conn, "SELECT COUNT(*) AS n FROM Class", one=True)["n"],
        "graduated":        _q(conn, "SELECT COUNT(*) AS n FROM Student WHERE status='graduated'", one=True)["n"],
        "withdrawn":        _q(conn, "SELECT COUNT(*) AS n FROM Student WHERE status='withdrawn'", one=True)["n"],
        "attendance_today": _q(conn, "SELECT status,COUNT(*) AS n FROM Attendance WHERE date=CURDATE() GROUP BY status"),
        "finals_pending":   _q(conn, """
            SELECT COUNT(DISTINCT gd.student_id) AS n FROM GradeDetail gd
            WHERE gd.semester_id=%s AND gd.final_exam IS NULL
        """, (sem_id,), one=True)["n"],
    }

    stats["failing_students"] = _q(conn, """
        SELECT s.student_id, s.f_name, s.l_name,
               sub.name AS subject,
               COALESCE(gd.total, g.mark) AS raw_mark
        FROM Student s
        JOIN Grades g   ON g.student_id = s.student_id AND g.semester_id=%s
        JOIN Subject sub ON g.subject_id = sub.subject_id
        LEFT JOIN GradeDetail gd ON gd.student_id=s.student_id
                                AND gd.subject_id=g.subject_id
                                AND gd.semester_id=g.semester_id
        WHERE s.status='active'
          AND g.mark < 60
          AND sub.name != 'Physical Education'
        ORDER BY g.mark ASC LIMIT 20
    """, (sem_id,))

    return stats


        SELECT s.f_name, s.l_name, c.grade, c.section,
               sub.name AS subject,
               gd.quiz1, gd.quiz2, gd.midterm, gd.final_exam
        FROM GradeDetail gd
        JOIN Student s  ON gd.student_id=s.student_id
        JOIN Subject sub ON gd.subject_id=sub.subject_id
        JOIN Class c    ON s.class_id=c.class_id
        WHERE gd.semester_id=(
            SELECT semester_id FROM Semester ORDER BY semester_id DESC LIMIT 1)
        ORDER BY gd.detail_id DESC
        LIMIT %s
    """, (limit,))


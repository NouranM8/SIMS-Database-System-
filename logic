def export_report_card_pdf(rc, out_path):
    """
    Generate a formatted PDF report card from a get_report_card() dict.
    Returns out_path on success, raises on failure.
    """
    from reportlab.lib.pagesizes import A4
    from reportlab.lib import colors
    from reportlab.lib.units import cm
    from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
    from reportlab.platypus import (SimpleDocTemplate, Paragraph, Spacer,
                                     Table, TableStyle, HRFlowable)
    from reportlab.lib.enums import TA_CENTER, TA_LEFT, TA_RIGHT

    # ── colour palette (matches the dark-blue app theme) ─────────────
    NAVY   = colors.HexColor("#1a2744")
    BLUE   = colors.HexColor("#2563eb")
    LIGHT  = colors.HexColor("#eff6ff")
    BORDER = colors.HexColor("#cbd5e1")
    GREEN  = colors.HexColor("#16a34a")
    RED    = colors.HexColor("#dc2626")
    AMBER  = colors.HexColor("#d97706")
    GREY   = colors.HexColor("#64748b")
    WHITE  = colors.white
    BLACK  = colors.HexColor("#0f172a")

    doc = SimpleDocTemplate(
        out_path, pagesize=A4,
        leftMargin=2*cm, rightMargin=2*cm,
        topMargin=2*cm, bottomMargin=2*cm,
    )

    styles = getSampleStyleSheet()
    def sty(name, parent="Normal", **kw):
        return ParagraphStyle(name, parent=styles[parent], **kw)

    S_SCHOOL  = sty("school",  fontSize=22, textColor=NAVY,  leading=26, alignment=TA_CENTER, fontName="Helvetica-Bold")
    S_SUB     = sty("sub",     fontSize=10, textColor=GREY,  leading=14, alignment=TA_CENTER)
    S_TITLE   = sty("title",   fontSize=14, textColor=WHITE, leading=18, alignment=TA_CENTER, fontName="Helvetica-Bold")
    S_LABEL   = sty("label",   fontSize=9,  textColor=GREY,  leading=13, fontName="Helvetica-Bold")
    S_VALUE   = sty("value",   fontSize=10, textColor=BLACK, leading=14)
    S_WARN    = sty("warn",    fontSize=9,  textColor=AMBER, leading=13, fontName="Helvetica-Bold")
    S_TH      = sty("th",      fontSize=9,  textColor=WHITE, leading=12, alignment=TA_CENTER, fontName="Helvetica-Bold")
    S_TD      = sty("td",      fontSize=9,  textColor=BLACK, leading=12, alignment=TA_CENTER)
    S_TD_L    = sty("td_l",    fontSize=9,  textColor=BLACK, leading=12, alignment=TA_LEFT)
    S_FOOTER  = sty("footer",  fontSize=8,  textColor=GREY,  leading=11, alignment=TA_CENTER)

    student  = rc["student"]
    semester = rc["semester"] or {}
    att      = rc["attendance"]
    gpa      = rc["gpa"]
    grades   = rc["grades"]
    avg      = rc["average"]
    avg_let  = rc["average_letter"]
    pending  = rc["finals_pending"]
    has_det  = rc["has_detail"]
    mx       = rc.get("max_components", {})

    sem_label = f"{semester.get('name','')} {semester.get('year_name','')}".strip()
    stu_name  = f"{student['f_name']} {student['l_name']}"
    class_lbl = f"Grade {student['grade']}-{student['section']}"

    story = []

    # ── School header ────────────────────────────────────────────────
    story.append(Paragraph("SIMS Academy", S_SCHOOL))
    story.append(Paragraph("School Information Management System", S_SUB))
    story.append(Spacer(1, 0.3*cm))
    story.append(HRFlowable(width="100%", thickness=2, color=NAVY))
    story.append(Spacer(1, 0.2*cm))

    # ── Report card banner ───────────────────────────────────────────
    banner_data = [[Paragraph("OFFICIAL REPORT CARD", S_TITLE)]]
    banner = Table(banner_data, colWidths=["100%"])
    banner.setStyle(TableStyle([
        ("BACKGROUND", (0,0), (-1,-1), NAVY),
        ("TOPPADDING",    (0,0), (-1,-1), 8),
        ("BOTTOMPADDING", (0,0), (-1,-1), 8),
        ("ROUNDEDCORNERS", [4]),
    ]))
    story.append(banner)

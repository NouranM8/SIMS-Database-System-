def get_report_card(conn, student_id, semester_id):
    student  = get_student_by_id(conn, student_id)
    semester = _q(conn, """
        SELECT sem.*, a.year_name, a.school_year_id
        FROM Semester sem JOIN AcademicYear a ON sem.school_year_id=a.school_year_id
        WHERE sem.semester_id=%s
    """, (semester_id,), one=True)

    rows = _q(conn, """
        SELECT sub.name AS subject, sub.subject_id,
               CONCAT(t.f_name,' ',t.l_name) AS teacher,
               g.mark AS pct, g.status AS letter_grade,
               gd.quiz1, gd.quiz2, gd.midterm, gd.final_exam, gd.total AS raw_total,
               CASE WHEN sub.name='Physical Education' THEN 1 ELSE 0 END AS is_pe,
               CASE WHEN gd.detail_id IS NOT NULL AND gd.final_exam IS NULL
                    THEN 1 ELSE 0 END AS final_pending
        FROM Subject sub
        JOIN Teacher t ON sub.teacher_id=t.teacher_id
        JOIN Enrollment e ON e.subject_id=sub.subject_id AND e.student_id=%s
        LEFT JOIN Grades g ON g.student_id=%s AND g.subject_id=sub.subject_id
                          AND g.semester_id=%s
        LEFT JOIN GradeDetail gd ON gd.student_id=%s AND gd.subject_id=sub.subject_id
                                AND gd.semester_id=%s
        WHERE sub.semester_id=%s
        ORDER BY is_pe, sub.name
    """, (student_id, student_id, semester_id, student_id, semester_id, semester_id))

    has_detail = any(r["quiz1"] is not None or r["midterm"] is not None
                     or r["final_exam"] is not None for r in rows)

    academic = [r for r in rows if not r["is_pe"] and r["pct"] is not None]
    avg_pct  = round(sum(float(r["pct"]) for r in academic) / len(academic), 1) if academic else None

    year_id = semester["school_year_id"] if semester else None
    gpa = _q(conn, "SELECT value,student_rank FROM GPA WHERE student_id=%s AND school_year_id=%s",
             (student_id, year_id), one=True) if year_id else None

    attendance = get_attendance_summary(conn, student_id, semester_id)

    return {
        "student":        student,
        "semester":       semester,
        "grades":         rows,
        "average":        avg_pct,
        "average_letter": _letter(avg_pct),
        "attendance":     attendance,
        "gpa":            gpa,
        "has_detail":     has_detail,
        "finals_pending": any(r.get("final_pending") for r in rows),
        "max_components": {"quiz1": MAX_QUIZ1, "quiz2": MAX_QUIZ2,
                           "midterm": MAX_MIDTERM, "final": MAX_FINAL, "total": MAX_TOTAL},
    }


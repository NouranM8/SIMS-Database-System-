def get_attendance_summary(conn, student_id, semester_id):
    rows = _q(conn, """
        SELECT status, COUNT(*) AS n FROM Attendance
        WHERE student_id=%s AND semester_id=%s GROUP BY status
    """, (student_id, semester_id))
    s = {"Present": 0, "Absent": 0, "Late": 0, "Excused": 0, "total": 0}
    for r in rows:
        s[r["status"]] = r["n"]; s["total"] += r["n"]
    s["percentage"] = (
        round((s["Present"]+s["Late"]+s["Excused"]) / s["total"] * 100, 1)
        if s["total"] else 0)
    s["flagged"] = s["percentage"] < 75
    return s


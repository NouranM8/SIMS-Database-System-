    return _q(conn, """
        SELECT s.student_id, s.f_name, s.l_name, s.gender, s.birth_date,
               s.status, c.grade, c.section
        FROM Student s JOIN Class c ON s.class_id=c.class_id
        WHERE s.status=%s
          AND (s.f_name LIKE %s OR s.l_name LIKE %s
               OR s.student_id LIKE %s OR CONCAT(c.grade,' ',c.section) LIKE %s)
        ORDER BY s.l_name
    """, (status, kw, kw, kw, kw))


def get_academic_years(conn):
    return _q(conn, "SELECT * FROM AcademicYear ORDER BY school_year_id DESC")

def get_semesters(conn, year_id=None):
    if year_id:
        return _q(conn,
            "SELECT * FROM Semester WHERE school_year_id=%s ORDER BY semester_id",
            (year_id,))
    return _q(conn, "SELECT * FROM Semester ORDER BY semester_id")

def get_semesters_with_year(conn):
    """Returns all semesters joined with AcademicYear for human-readable labels."""
    return _q(conn, """
        SELECT s.semester_id, s.name, s.school_year_id, a.year_name,
               CONCAT(s.name, ' ', a.year_name) AS full_label
        FROM Semester s
        JOIN AcademicYear a ON s.school_year_id = a.school_year_id
        ORDER BY s.semester_id
    """)

def get_active_semester(conn):
    """Always the latest semester in the database."""
    return _q(conn, """
        SELECT s.*, a.year_name
        FROM Semester s
        JOIN AcademicYear a ON s.school_year_id = a.school_year_id
        ORDER BY s.semester_id DESC LIMIT 1
    """, one=True)

def add_academic_year(conn, year_label):
    if _q(conn, "SELECT school_year_id FROM AcademicYear WHERE year_name=%s",
          (year_label,), one=True):
        return None, None, f"Year '{year_label}' already exists."
    yid = _run(conn, "INSERT INTO AcademicYear (year_name) VALUES (%s)", (year_label,))
    fid = _run(conn, "INSERT INTO Semester (name,school_year_id) VALUES ('Fall',%s)", (yid,))
    return yid, fid, f"Year {year_label} created with Fall semester."

def add_spring_semester(conn, year_id):
    if _q(conn, "SELECT semester_id FROM Semester WHERE school_year_id=%s AND name='Spring'",
          (year_id,), one=True):
        return None, "Spring semester already exists for this year."
    sid = _run(conn, "INSERT INTO Semester (name,school_year_id) VALUES ('Spring',%s)", (year_id,))
    return sid, "Spring semester added."


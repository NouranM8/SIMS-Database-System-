    return _q(conn, """
        SELECT s.student_id, s.f_name, s.l_name, c.grade, c.section,
               COUNT(*) AS total_days,
               SUM(CASE WHEN a.status IN ('Present','Late','Excused') THEN 1 ELSE 0 END) AS attended,
               ROUND(SUM(CASE WHEN a.status IN ('Present','Late','Excused') THEN 1 ELSE 0 END)
                     /COUNT(*)*100,1) AS pct
        FROM Attendance a
        JOIN Student s ON a.student_id=s.student_id
        JOIN Class   c ON s.class_id=c.class_id
        WHERE a.semester_id=%s AND s.status='active'
        GROUP BY s.student_id, s.f_name, s.l_name, c.grade, c.section
        HAVING pct < %s ORDER BY pct ASC
    """, (semester_id, threshold))


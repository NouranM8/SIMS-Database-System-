def get_class_subjects_for_semester(conn, class_id, semester_id):
    """All subjects for a given class in the given semester."""
    return _q(conn, """
        SELECT DISTINCT sub.subject_id, sub.name,
               CONCAT(t.f_name,' ',t.l_name) AS teacher_name,
               t.teacher_id,
               COUNT(e.enrollment_id) AS enrolled_students
        FROM Subject sub
        JOIN Teacher t ON sub.teacher_id = t.teacher_id
        LEFT JOIN Enrollment e ON e.subject_id = sub.subject_id
        LEFT JOIN Student s ON e.student_id = s.student_id AND s.class_id = %s
        WHERE sub.semester_id = %s
          AND sub.subject_id IN (
              SELECT sub2.subject_id FROM Subject sub2
              JOIN Enrollment e2 ON e2.subject_id = sub2.subject_id
              JOIN Student s2 ON e2.student_id = s2.student_id
              WHERE s2.class_id = %s AND sub2.semester_id = %s
          )
        GROUP BY sub.subject_id, sub.name, t.teacher_id, t.f_name, t.l_name
        ORDER BY sub.name
    """, (class_id, semester_id, class_id, semester_id))

def get_unenrolled_students(conn, subject_id):
    """Students in the same class but not enrolled in a given subject."""
    return _q(conn, """
        SELECT s.student_id, CONCAT(s.f_name,' ',s.l_name) AS student_name,
               c.grade, c.section
        FROM Student s
        JOIN Class c ON s.class_id = c.class_id
        JOIN Subject sub ON sub.subject_id = %s
        JOIN Enrollment e_any ON e_any.subject_id = sub.subject_id
        JOIN Student ref ON e_any.student_id = ref.student_id
        WHERE s.class_id = ref.class_id
          AND s.status = 'active'
          AND s.student_id NOT IN (
              SELECT e.student_id FROM Enrollment e WHERE e.subject_id = %s
          )
        GROUP BY s.student_id, s.f_name, s.l_name, c.grade, c.section
        ORDER BY s.l_name
        LIMIT 1
    """, (subject_id, subject_id), one=True)  # just to detect if any exist

def bulk_enroll_class(conn, class_id, semester_id):
    """Enroll all active students in a class into all subjects for that semester.
    Safe to call multiple times — uses INSERT IGNORE.
    Returns count of new enrollments created."""
    subjects = _q(conn, """
        SELECT DISTINCT sub.subject_id
        FROM Subject sub
        WHERE sub.semester_id = %s
          AND EXISTS (
            SELECT 1 FROM Enrollment e
            JOIN Student s ON e.student_id = s.student_id
            WHERE e.subject_id = sub.subject_id AND s.class_id = %s
          )
    """, (semester_id, class_id))

    students = _q(conn, """
        SELECT student_id FROM Student
        WHERE class_id = %s AND status = 'active'
    """, (class_id,))

    count = 0
    for sub in subjects:
        for stu in students:
            existing = _q(conn,
                "SELECT enrollment_id FROM Enrollment WHERE student_id=%s AND subject_id=%s",
                (stu["student_id"], sub["subject_id"]), one=True)
            if not existing:
                _run(conn, "INSERT INTO Enrollment (student_id,subject_id) VALUES (%s,%s)",
                     (stu["student_id"], sub["subject_id"]))
                count += 1
    return count

def assign_teacher_to_subject(conn, subject_id, teacher_id):

def save_grade_detail(conn, student_id, subject_id, semester_id,
                      quiz1=None, quiz2=None, midterm=None, final_exam=None):
    try:
        q1 = _validate_component(quiz1,      MAX_QUIZ1,   "Quiz 1")
        q2 = _validate_component(quiz2,      MAX_QUIZ2,   "Quiz 2")
        mt = _validate_component(midterm,    MAX_MIDTERM, "Midterm")
        fn = _validate_component(final_exam, MAX_FINAL,   "Final exam")
    except ValueError as e:
        return None, None, str(e)

    total_raw = _compute_total(q1, q2, mt, fn)
    pct       = _raw_to_pct(total_raw)

    if _q(conn, """SELECT detail_id FROM GradeDetail
                   WHERE student_id=%s AND subject_id=%s AND semester_id=%s""",
          (student_id, subject_id, semester_id), one=True):
        _run(conn, """
            UPDATE GradeDetail SET quiz1=%s,quiz2=%s,midterm=%s,final_exam=%s,total=%s
            WHERE student_id=%s AND subject_id=%s AND semester_id=%s
        """, (q1, q2, mt, fn, total_raw, student_id, subject_id, semester_id))
    else:
        _run(conn, """
            INSERT INTO GradeDetail
                (student_id,subject_id,semester_id,quiz1,quiz2,midterm,final_exam,total)
            VALUES (%s,%s,%s,%s,%s,%s,%s,%s)
        """, (student_id, subject_id, semester_id, q1, q2, mt, fn, total_raw))

    if pct is not None:
        _save_grade_pct(conn, student_id, subject_id, semester_id, pct)

    return total_raw, pct, None

def _save_grade_pct(conn, student_id, subject_id, semester_id, pct):
    status = _letter(pct)
    if _q(conn, """SELECT grade_id FROM Grades
                   WHERE student_id=%s AND subject_id=%s AND semester_id=%s""",
          (student_id, subject_id, semester_id), one=True):
        _run(conn, """UPDATE Grades SET mark=%s,status=%s
                      WHERE student_id=%s AND subject_id=%s AND semester_id=%s""",
             (pct, status, student_id, subject_id, semester_id))
    else:
        _run(conn, """INSERT INTO Grades (student_id,subject_id,semester_id,mark,status)
                      VALUES (%s,%s,%s,%s,%s)""",
             (student_id, subject_id, semester_id, pct, status))

def save_grade(conn, student_id, subject_id, semester_id, mark):
    if float(mark) < 0 or float(mark) > 100:
        raise ValueError("Mark must be between 0 and 100.")
    _save_grade_pct(conn, student_id, subject_id, semester_id, float(mark))


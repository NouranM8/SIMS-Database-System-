def _parse_and_build(text, role="admin", teacher_id=None):
    """
    Parse free-form English text, match intent, build SQL.
    Returns (intent_id, sql) or (None, None).
    """
    t = text.strip().lower()

    for intent_id, match_fn, sql_fn in _build_intents():
        try:
            if match_fn(t):
                sql = sql_fn(t).strip()
                # Teacher role: scope to their subjects
                if role == "teacher" and teacher_id and "sub.teacher_id" not in sql:
                    if "Subject sub" in sql and "JOIN Subject" in sql:
                        sql = sql.replace(
                            f"WHERE sub.semester_id={_SEM}",
                            f"WHERE sub.semester_id={_SEM} AND sub.teacher_id={teacher_id}"
                        ).replace(
                            "WHERE sub.name",
                            f"WHERE sub.teacher_id={teacher_id} AND sub.name"
                        )
                return intent_id, sql
        except Exception:
            continue
    return None, None


def run_query_assistant(conn, user_question, role="admin", teacher_id=None):
    """
    Convert a natural language question → SQL → execute → return results.
    No API, no download, instant.
    """
    intent_id, sql = _parse_and_build(user_question, role, teacher_id)

    if not sql:
        return {"label": None, "sql": None, "columns": [], "rows": [],
                "summary": None, "matched": False, "error": None}

    try:
        cur = conn.cursor(dictionary=True)
        cur.execute(sql)
        rows = cur.fetchall()
        cols = [d[0] for d in cur.description] if cur.description else []
        cur.close()
    except Exception as e:
        return {"label": intent_id, "sql": sql, "columns": [], "rows": [],
                "summary": None, "matched": True, "error": f"Query error: {e}"}

    n = len(rows)
    if n == 0:
        summary = "No results found."
    elif n == 1 and len(cols) == 1:
        val = list(rows[0].values())[0]
        summary = f"Result: {val}"
    else:
        summary = f"{n} row{'s' if n != 1 else ''} returned."

    return {"label": intent_id, "sql": sql, "columns": cols, "rows": rows,
            "summary": summary, "matched": True, "error": None}


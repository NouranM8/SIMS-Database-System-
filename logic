def save_phones(conn, entity_type, entity_id, phones):
    """phones = list of (phone_number, label) tuples. Replaces existing."""
    _run(conn, "DELETE FROM ContactPhone WHERE entity_type=%s AND entity_id=%s",
         (entity_type, entity_id))
    for number, label in phones:
        if number and number.strip():
            _run(conn, """
                INSERT INTO ContactPhone (entity_type, entity_id, phone_number, label)
                VALUES (%s,%s,%s,%s)
            """, (entity_type, entity_id, number.strip(), label or "Primary"))


def get_grades_by_student(conn, student_id):
    """Historical grades from Grades table (completed semesters only)."""
    return _q(conn, """
        SELECT g.grade_id, sub.name AS subject, g.mark AS pct, g.status,
               sem.name AS semester, a.year_name, a.school_year_id,
               CASE WHEN sub.name='Physical Education' THEN 1 ELSE 0 END AS is_pe,
               gd.quiz1, gd.quiz2, gd.midterm, gd.final_exam, gd.total AS raw_total
        FROM Grades g
        JOIN Subject      sub ON g.subject_id      = sub.subject_id
        JOIN Semester     sem ON g.semester_id      = sem.semester_id
        JOIN AcademicYear a   ON sem.school_year_id = a.school_year_id
        LEFT JOIN GradeDetail gd ON gd.student_id =g.student_id
                                AND gd.subject_id =g.subject_id
                                AND gd.semester_id=g.semester_id
        WHERE g.student_id=%s
        ORDER BY a.school_year_id, sem.semester_id, sub.name
    """, (student_id,))

def get_full_grade_history(conn, student_id):
    """
    Returns ALL semesters including those where finals are pending (no Grades row yet).
    Uses GradeDetail as master — shows quiz/mid even when final not yet entered.
    Only returns rows where at least some data exists (GradeDetail or Grades row).
    result_status = 'Pending' when final_exam IS NULL, 'Pass'/'Fail' when complete.
    """
    return _q(conn, """
        SELECT
            a.year_name,
            sem.name          AS semester_name,
            sem.semester_id,
            sub.name          AS subject,
            sub.subject_id,
            CASE WHEN sub.name='Physical Education' THEN 1 ELSE 0 END AS is_pe,
            gd.quiz1,
            gd.quiz2,
            gd.midterm,
            gd.final_exam,
            gd.total          AS raw_total,
            g.mark            AS pct,
            CASE
                WHEN gd.detail_id IS NOT NULL AND gd.final_exam IS NULL THEN 'Pending'
                WHEN g.mark IS NULL                                     THEN '—'
                WHEN g.mark >= 60                                       THEN 'Pass'
                ELSE 'Fail'
            END               AS result_status,
            CASE WHEN gd.detail_id IS NOT NULL THEN 1 ELSE 0 END AS has_detail
        FROM Enrollment e
        JOIN Subject      sub ON sub.subject_id    = e.subject_id
        JOIN Semester     sem ON sub.semester_id   = sem.semester_id
        JOIN AcademicYear a   ON sem.school_year_id = a.school_year_id
        LEFT JOIN GradeDetail gd ON gd.student_id  = e.student_id
                                AND gd.subject_id  = sub.subject_id
                                AND gd.semester_id = sem.semester_id
        LEFT JOIN Grades g       ON g.student_id   = e.student_id
                                AND g.subject_id   = sub.subject_id
                                AND g.semester_id  = sem.semester_id
        WHERE e.student_id = %s
          AND (gd.detail_id IS NOT NULL OR g.grade_id IS NOT NULL)
        ORDER BY a.school_year_id, sem.semester_id, is_pe, sub.name
    """, (student_id,))


# ═══════════════════════════════════════════════════════════════════

def check_finals_pending(conn, year_id):
    """Legacy wrapper — returns total issue count for backward compatibility."""
    return check_finals_complete(conn, year_id)["total_issues"]

def process_end_of_year(conn, year_id):
    check = check_finals_complete(conn, year_id)
    if check["total_issues"] > 0:
        parts = []
        if check["missing_any"]:
            parts.append(f"{check['missing_any']} student(s) have subjects with no grades entered at all")
        if check["pending_final"]:
            parts.append(f"{check['pending_final']} student(s) still have pending final exam grades")
        return {
            "blocked": True,
            "reason":  ". ".join(parts) + ". All final exam grades must be entered before processing.",
        }

    sems = _q(conn, "SELECT semester_id FROM Semester WHERE school_year_id=%s", (year_id,))
    sem_ids = [s["semester_id"] for s in sems]
    if not sem_ids:
        return {"blocked": True, "reason": "No semesters found for this year."}

    placeholders = ",".join(["%s"] * len(sem_ids))
    students = _q(conn, """
        SELECT s.student_id, s.f_name, s.l_name, c.grade, c.class_id
        FROM Student s JOIN Class c ON s.class_id=c.class_id
        WHERE s.status='active' ORDER BY c.grade, s.l_name
    """)

    promoted  = []
    graduated = []
    repeated  = []
    no_data   = []

    for st in students:
        sid = st["student_id"]

        subject_marks = _q(conn, f"""
            SELECT sub.name AS subject, g.mark
            FROM Grades g
            JOIN Subject  sub ON g.subject_id =sub.subject_id
            WHERE g.student_id=%s
              AND g.semester_id IN ({placeholders})
              AND sub.name!='Physical Education'
        """, tuple([sid] + sem_ids))

        if not subject_marks:
            no_data.append(st); continue

        failed_subjects = [r["subject"] for r in subject_marks
                           if r["mark"] is None or float(r["mark"]) < 60]
        passed_all = len(failed_subjects) == 0

        calculate_and_save_gpa(conn, sid, year_id)

        if passed_all:
            if st["grade"] == 12:
                _run(conn, "UPDATE Student SET status='graduated' WHERE student_id=%s", (sid,))
                graduated.append({**st, "failed_subjects": []})
            else:
                promoted.append({**st, "failed_subjects": []})
        else:
            repeated.append({**st, "failed_subjects": failed_subjects})

    _update_class_rankings(conn, year_id)

    return {
        "blocked":  False,
        "promoted":  promoted,
        "graduated": graduated,
        "repeated":  repeated,
        "no_data":   no_data,
        "year_id":   year_id,
    }

def _update_class_rankings(conn, year_id):
    for cls in _q(conn, "SELECT class_id FROM Class"):
        students = _q(conn, """
            SELECT s.student_id, gpa.value FROM Student s
            JOIN GPA gpa ON gpa.student_id=s.student_id
            WHERE s.class_id=%s AND gpa.school_year_id=%s
            ORDER BY gpa.value DESC
        """, (cls["class_id"], year_id))
        for rank, s in enumerate(students, 1):
            _run(conn, "UPDATE GPA SET student_rank=%s WHERE student_id=%s AND school_year_id=%s",
                 (rank, s["student_id"], year_id))


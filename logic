def _q(conn, sql, params=(), one=False):
    cur = conn.cursor(dictionary=True)
    cur.execute(sql, params)
    result = cur.fetchone() if one else cur.fetchall()
    cur.close()
    return result

def _run(conn, sql, params=()):
    cur = conn.cursor()
    cur.execute(sql, params)
    last_id = cur.lastrowid
    cur.close()
    return last_id

def _hash(pw):
    return hashlib.sha256(pw.encode()).hexdigest()

def generate_password():
    c = random.choices(string.ascii_lowercase, k=4) + random.choices(string.digits, k=4)
    random.shuffle(c)
    return "".join(c)

# ═══════════════════════════════════════════════════════════════════
#  GRADE WEIGHTS & RULES
#  quiz1=10, quiz2=10, midterm=20, final=60 → max raw = 100
#  Pass mark = 60/100 (60%)
# ═══════════════════════════════════════════════════════════════════

MAX_QUIZ1    = 10
MAX_QUIZ2    = 10
MAX_MIDTERM  = 20
MAX_FINAL    = 60
MAX_TOTAL    = MAX_QUIZ1 + MAX_QUIZ2 + MAX_MIDTERM + MAX_FINAL   # 100
PASS_RAW     = int(MAX_TOTAL * 0.60)   # 60 out of 100 = 60%
PASS_MARK    = 60   # percentage equivalent stored in Grades.mark

def _validate_component(value, max_val, name):
    if value is None:
        return None
    v = float(value)
    if v < 0 or v > max_val:
        raise ValueError(f"{name} must be between 0 and {max_val}. Got {v}.")
    return round(v, 1)

def _compute_total(quiz1, quiz2, midterm, final_exam):
    if final_exam is None:
        return None
    q1 = quiz1 or 0
    q2 = quiz2 or 0
    mt = midterm or 0
    return round(q1 + q2 + mt + float(final_exam), 1)

def _raw_to_pct(raw):
    if raw is None:
        return None
    return round(raw, 1)

def _letter(pct):
    if pct is None: return "—"
    if pct >= 90: return "A"
    if pct >= 80: return "B"
    if pct >= 70: return "C"
    if pct >= 60: return "D"
    return "F"


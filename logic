#  SMART NLP QUERY ENGINE  — no API, no download, instant
#  Converts free-form English sentences → SQL → live DB results
# ═══════════════════════════════════════════════════════════════════
import re as _re

# ── Subquery constants ───────────────────────────────────────────
_SEM  = "(SELECT semester_id    FROM Semester     ORDER BY semester_id    DESC LIMIT 1)"
_YEAR = "(SELECT school_year_id FROM AcademicYear ORDER BY school_year_id DESC LIMIT 1)"

# ── Stopwords to strip before matching ──────────────────────────
_STOP = {"i","want","the","a","an","of","in","for","to","show","me","give",
         "list","get","find","all","that","are","is","was","were","have",
         "has","how","many","what","which","who","please","can","you","tell",
         "number","count","total","students","student","teachers","teacher",
         "their","from","with","and","or","this","current","latest","active",
         "semester","class","grade","section","my","do","did","had"}

# ── Entity extractors ────────────────────────────────────────────

def _grade(t):
    """Extract grade number 7-12."""
    m = _re.search(r'\b(grade\s*)?([7-9]|1[0-2])\b', t, _re.I)
    return int(m.group(2)) if m else None

def _section(t):
    """Extract section A or B."""
    m = _re.search(r'\bsection\s*([AB])\b|\b([AB])\s*section\b|'
                   r'\bgrade\s*\d+\s*[-–]?\s*([AB])\b|\b(\d+)\s*[-–]\s*([AB])\b', t, _re.I)
    if m:
        for g in m.groups():
            if g and g.upper() in ('A','B'):
                return g.upper()
    return None

def _limit(t, default=10):
    """Extract top-N number, ignoring grade numbers."""
    # Remove grade references first
    clean = _re.sub(r'\b(grade\s*)?([7-9]|1[0-2])\b', '', t, flags=_re.I)
    m = _re.search(r'\b(\d+)\b', clean)
    n = int(m.group(1)) if m else default
    return max(1, min(n, 100))

def _subject(t):
    """Extract subject name if mentioned."""
    subjects = ["mathematics","math","science","physics","chemistry","biology",
                "english","arabic","history","geography","computer","art",
                "physical education","pe","economics","literature"]
    tl = t.lower()
    for s in subjects:
        if s in tl:
            if s == "math": return "Mathematics"
            if s == "pe":   return "Physical Education"
            return s.title()
    return None

def _gender(t):
    tl = t.lower()
    if any(w in tl for w in ["male","boy","boys","men"]):    return "Male"
    if any(w in tl for w in ["female","girl","girls","women"]): return "Female"
    return None

def _has(t, *words):
    tl = t.lower()
    return any(w in tl for w in words)

def _all(t, *words):
    tl = t.lower()
    return all(w in tl for w in words)

# ── SQL builder helpers ──────────────────────────────────────────

def _grade_filter(g, alias="c"):
    return f"AND {alias}.grade = {g} " if g else ""

def _section_filter(s, alias="c"):
    return f"AND {alias}.section = '{s}' " if s else ""

def _subject_filter(sub, alias="sub"):
    return f"AND {alias}.name = '{sub}' " if sub else ""

# ═══════════════════════════════════════════════════════════════════
#  INTENT → SQL MAP
#  Each entry: (intent_id, match_fn, sql_fn)
#  match_fn(text) → True/False
#  sql_fn(text)   → SQL string
# ═══════════════════════════════════════════════════════════════════

def _build_intents():
    return [

    # ════════════ STUDENT COUNTS ════════════════════════════════

    ("count_students_grade",
     lambda t: _has(t,"student","pupil") and _grade(t) and _has(t,"how many","number","count","total"),
     lambda t: f"""
        SELECT c.grade, c.section,
               COUNT(s.student_id) AS student_count
        FROM Student s JOIN Class c ON s.class_id=c.class_id
        WHERE s.status='active' AND c.grade={_grade(t)}
              {_section_filter(_section(t))}
        GROUP BY c.grade, c.section
        ORDER BY c.section"""),

    ("count_students_total",
     lambda t: _has(t,"how many","number of","count","total") and _has(t,"student","pupil")
               and not _grade(t) and not _has(t,"fail","absent","pass","attend","gender","male","female","boy","girl"),
     lambda t: """
        SELECT
          SUM(CASE WHEN status='active'    THEN 1 ELSE 0 END) AS active,
          SUM(CASE WHEN status='graduated' THEN 1 ELSE 0 END) AS graduated,
          SUM(CASE WHEN status='withdrawn' THEN 1 ELSE 0 END) AS withdrawn,
          COUNT(*) AS total_all
        FROM Student"""),

    ("count_per_class",
     lambda t: _has(t,"how many","number","count") and _has(t,"class","each class","per class"),
     lambda t: """
        SELECT c.grade, c.section,
               COUNT(s.student_id) AS student_count
        FROM Class c
        LEFT JOIN Student s ON s.class_id=c.class_id AND s.status='active'
        GROUP BY c.class_id, c.grade, c.section
        ORDER BY c.grade, c.section"""),

    # ════════════ LIST STUDENTS ══════════════════════════════════

    ("list_students_grade",
     lambda t: _has(t,"student","pupil") and _grade(t) and not _has(t,"fail","pass","absent","gpa","average","count","how many","number"),
     lambda t: f"""
        SELECT s.student_id,
               CONCAT(s.f_name,' ',s.l_name) AS student_name,
               s.gender, c.grade, c.section
        FROM Student s JOIN Class c ON s.class_id=c.class_id
        WHERE s.status='active' AND c.grade={_grade(t)}
              {_section_filter(_section(t))}
        ORDER BY c.section, s.l_name"""),


    ("most_absent",
     lambda t: _has(t,"absent","miss","missed","skip","skipped","absences","most absent"),
     lambda t: f"""
        SELECT CONCAT(s.f_name,' ',s.l_name) AS student_name,
               c.grade, c.section,
               COUNT(*) AS absent_days
        FROM Attendance a
        JOIN Student s ON a.student_id=s.student_id
        JOIN Class c ON s.class_id=c.class_id
        WHERE a.status='Absent' AND a.semester_id={_SEM}
          AND s.status='active' {_grade_filter(_grade(t))}
        GROUP BY s.student_id, s.f_name, s.l_name, c.grade, c.section
        ORDER BY absent_days DESC LIMIT {_limit(t, 20)}"""),
    ("list_all_students",
     lambda t: _has(t,"all student","all pupils","list student","show student","every student")
               and not _grade(t)
               and not _has(t,"fail","absent","attend","gpa","average","pass","improv","more than","multiple"),
     lambda t: """
        SELECT s.student_id,
               CONCAT(s.f_name,' ',s.l_name) AS student_name,
               c.grade, c.section, s.gender, s.status
        FROM Student s JOIN Class c ON s.class_id=c.class_id
        WHERE s.status='active'
        ORDER BY c.grade, c.section, s.l_name LIMIT 100"""),

    ("gender_count",
     lambda t: _has(t,"how many","number","count") and _gender(t),
     lambda t: f"""
        SELECT c.grade, c.section,
               COUNT(*) AS count
        FROM Student s JOIN Class c ON s.class_id=c.class_id
        WHERE s.status='active'
          AND s.gender='{_gender(t)}'
          {_grade_filter(_grade(t))}
        GROUP BY c.grade, c.section
        ORDER BY c.grade, c.section"""),

    ("gender_breakdown",
     lambda t: _has(t,"gender","male","female","boy","girl") and not _has(t,"how many","count"),
     lambda t: """
        SELECT c.grade, c.section,
               SUM(CASE WHEN s.gender='Male'   THEN 1 ELSE 0 END) AS male,
               SUM(CASE WHEN s.gender='Female' THEN 1 ELSE 0 END) AS female,
               COUNT(*) AS total
        FROM Student s JOIN Class c ON s.class_id=c.class_id
        WHERE s.status='active'
        GROUP BY c.grade, c.section ORDER BY c.grade, c.section"""),

    # ════════════ FAILING / PASSING ══════════════════════════════

    ("count_failing",
     lambda t: _has(t,"how many","number","count") and _has(t,"fail","failing","failed","not pass","didn't pass"),
     lambda t: f"""
        SELECT COUNT(DISTINCT s.student_id) AS failing_students
        FROM Student s
        JOIN Class c ON s.class_id=c.class_id
        JOIN Enrollment e ON e.student_id=s.student_id
        JOIN Subject sub ON e.subject_id=sub.subject_id
        LEFT JOIN Grades g ON g.student_id=s.student_id
                           AND g.subject_id=sub.subject_id
                           AND g.semester_id={_SEM}
        LEFT JOIN GradeDetail gd ON gd.student_id=s.student_id
                                 AND gd.subject_id=sub.subject_id
                                 AND gd.semester_id={_SEM}
        WHERE sub.semester_id={_SEM} AND s.status='active'
          AND sub.name != 'Physical Education'
          AND COALESCE(g.mark, gd.total) < 60
          AND COALESCE(g.mark, gd.total) IS NOT NULL
          {_grade_filter(_grade(t))}"""),


    ("failing_multiple",
     lambda t: _has(t,"fail","failing","failed") and _has(t,"more than","at least","multiple","several","2 subject","two subject","more subject"),
     lambda t: f"""
        SELECT CONCAT(s.f_name,' ',s.l_name) AS student_name,
               c.grade, c.section,
               COUNT(*) AS subjects_failed,
               GROUP_CONCAT(sub.name ORDER BY sub.name SEPARATOR ', ') AS failed_subjects
        FROM Student s
        JOIN Class c ON s.class_id=c.class_id
        JOIN Enrollment e ON e.student_id=s.student_id
        JOIN Subject sub ON e.subject_id=sub.subject_id
        LEFT JOIN Grades g ON g.student_id=s.student_id AND g.subject_id=sub.subject_id AND g.semester_id={_SEM}
        LEFT JOIN GradeDetail gd ON gd.student_id=s.student_id AND gd.subject_id=sub.subject_id AND gd.semester_id={_SEM}
        WHERE sub.semester_id={_SEM} AND s.status='active'
          AND sub.name != 'Physical Education'
          AND COALESCE(g.mark, gd.total) < 60
          {_grade_filter(_grade(t))}
        GROUP BY s.student_id, s.f_name, s.l_name, c.grade, c.section
        HAVING subjects_failed >= 2
        ORDER BY subjects_failed DESC"""),
    ("failing_students",
     lambda t: _has(t,"fail","failing","failed","not pass","below 60")
               and not _has(t,"how many","number","count")
               and not (_has(t,"teacher") and _has(t,"most","highest")),
     lambda t: f"""
        SELECT DISTINCT
               CONCAT(s.f_name,' ',s.l_name) AS student_name,
               c.grade, c.section,
               sub.name AS subject,
               ROUND(COALESCE(g.mark, gd.total),1) AS mark
        FROM Student s
        JOIN Class c ON s.class_id=c.class_id
        JOIN Enrollment e ON e.student_id=s.student_id
        JOIN Subject sub ON e.subject_id=sub.subject_id
        LEFT JOIN Grades g ON g.student_id=s.student_id
                           AND g.subject_id=sub.subject_id
                           AND g.semester_id={_SEM}
        LEFT JOIN GradeDetail gd ON gd.student_id=s.student_id
                                 AND gd.subject_id=sub.subject_id
                                 AND gd.semester_id={_SEM}
        WHERE sub.semester_id={_SEM} AND s.status='active'
          AND sub.name != 'Physical Education'
          AND COALESCE(g.mark, gd.total) < 60
          AND COALESCE(g.mark, gd.total) IS NOT NULL
          {_grade_filter(_grade(t))}
          {_subject_filter(_subject(t))}
        ORDER BY c.grade, c.section, mark ASC LIMIT 100"""),


    ("passing_students",
     lambda t: _has(t,"pass","passing","passed") and not _has(t,"fail","how many","count"),
     lambda t: f"""
        SELECT CONCAT(s.f_name,' ',s.l_name) AS student_name,
               c.grade, c.section,
               ROUND(AVG(COALESCE(g.mark,gd.total)),1) AS average_mark
        FROM Student s
        JOIN Class c ON s.class_id=c.class_id
        JOIN Enrollment e ON e.student_id=s.student_id
        JOIN Subject sub ON e.subject_id=sub.subject_id
        LEFT JOIN Grades g ON g.student_id=s.student_id AND g.subject_id=sub.subject_id AND g.semester_id={_SEM}
        LEFT JOIN GradeDetail gd ON gd.student_id=s.student_id AND gd.subject_id=sub.subject_id AND gd.semester_id={_SEM}
        WHERE sub.semester_id={_SEM} AND s.status='active'
          AND sub.name != 'Physical Education'
          AND COALESCE(g.mark, gd.total) IS NOT NULL
          {_grade_filter(_grade(t))}
        GROUP BY s.student_id, s.f_name, s.l_name, c.grade, c.section
        HAVING MIN(COALESCE(g.mark, gd.total)) >= 60
        ORDER BY average_mark DESC LIMIT 100"""),

    # ════════════ GPA / RANKINGS ══════════════════════════════════

    ("top_students",
     lambda t: _has(t,"top","best","highest gpa","highest grade","rank","honour","honor") and not _has(t,"class","average","attendance"),
     lambda t: f"""
        SELECT RANK() OVER (ORDER BY gpa.value DESC) AS school_rank,
               CONCAT(s.f_name,' ',s.l_name) AS student_name,
               c.grade, c.section,
               ROUND(gpa.value,2) AS gpa
        FROM GPA gpa
        JOIN Student s ON gpa.student_id=s.student_id
        JOIN Class   c ON s.class_id=c.class_id
        WHERE gpa.school_year_id={_YEAR} AND s.status='active'
              {_grade_filter(_grade(t))}
        ORDER BY gpa.value DESC
        LIMIT {_limit(t, 10)}"""),

    ("class_ranking",
     lambda t: _has(t,"rank","ranking","top","best") and _has(t,"class") and _grade(t),
     lambda t: f"""
        SELECT RANK() OVER (ORDER BY AVG(COALESCE(g.mark,gd.total)) DESC) AS class_rank,
               CONCAT(s.f_name,' ',s.l_name) AS student_name,
               c.section,
               ROUND(AVG(COALESCE(g.mark,gd.total)),2) AS average_mark
        FROM Student s
        JOIN Class c ON s.class_id=c.class_id
        JOIN Enrollment e ON e.student_id=s.student_id
        JOIN Subject sub ON e.subject_id=sub.subject_id
        LEFT JOIN Grades g ON g.student_id=s.student_id AND g.subject_id=sub.subject_id AND g.semester_id={_SEM}
        LEFT JOIN GradeDetail gd ON gd.student_id=s.student_id AND gd.subject_id=sub.subject_id AND gd.semester_id={_SEM}
        WHERE sub.semester_id={_SEM} AND c.grade={_grade(t)}
          AND s.status='active' AND sub.name != 'Physical Education'

DROP DATABASE sims;
CREATE DATABASE sims;
USE sims;

-- ================================================================
-- CORE TABLES
-- ================================================================

-- ── Academic Year ─────────────────────────────────────────────────
CREATE TABLE AcademicYear (
    school_year_id INT AUTO_INCREMENT PRIMARY KEY,
    year_name      VARCHAR(20) NOT NULL,
    UNIQUE KEY uq_year_name (year_name)          -- FIX 1: prevent duplicate years
);

-- ── Semester ──────────────────────────────────────────────────────
CREATE TABLE Semester (
    semester_id    INT AUTO_INCREMENT PRIMARY KEY,
    name           VARCHAR(20) NOT NULL,
    school_year_id INT NOT NULL,
    UNIQUE KEY uq_semester (name, school_year_id), -- FIX 2: prevent duplicate semesters per year
    FOREIGN KEY (school_year_id) REFERENCES AcademicYear(school_year_id)
        ON DELETE CASCADE
);

-- ── Teacher ───────────────────────────────────────────────────────
CREATE TABLE Teacher (
    teacher_id INT AUTO_INCREMENT PRIMARY KEY,
    f_name     VARCHAR(50),
    l_name     VARCHAR(50),
    email      VARCHAR(100) UNIQUE,
    phone_no   VARCHAR(20),
    gender     VARCHAR(10),
    birth_date DATE
);

-- ── Class ─────────────────────────────────────────────────────────
CREATE TABLE Class (
    class_id            INT AUTO_INCREMENT PRIMARY KEY,
    grade               INT     NOT NULL,
    section             CHAR(1) NOT NULL,
    homeroom_teacher_id INT,
    FOREIGN KEY (homeroom_teacher_id) REFERENCES Teacher(teacher_id)
        ON DELETE SET NULL
);

-- ── Guardian ──────────────────────────────────────────────────────
CREATE TABLE Guardian (
    guardian_id INT AUTO_INCREMENT PRIMARY KEY,
    f_name      VARCHAR(50),
    l_name      VARCHAR(50),
    phone_no    VARCHAR(20),
    gender      VARCHAR(10)
);

-- ── Student ───────────────────────────────────────────────────────
-- FIX 7: added status and enrollment_year used in many queries
CREATE TABLE Student (
    student_id      INT AUTO_INCREMENT PRIMARY KEY,
    f_name          VARCHAR(50),
    l_name          VARCHAR(50),
    gender          VARCHAR(10),
    birth_date      DATE,
    address         TEXT,
    guardian_id     INT,
    class_id        INT,
    status          VARCHAR(20) NOT NULL DEFAULT 'active',    -- FIX 7a
    enrollment_year INT        NULL,                          -- FIX 7b
    FOREIGN KEY (guardian_id) REFERENCES Guardian(guardian_id)
        ON DELETE SET NULL,
    FOREIGN KEY (class_id)    REFERENCES Class(class_id)
        ON DELETE SET NULL
);

-- ── Subject ───────────────────────────────────────────────────────
CREATE TABLE Subject (
    subject_id  INT AUTO_INCREMENT PRIMARY KEY,
    name        VARCHAR(50) NOT NULL,
    teacher_id  INT,
    semester_id INT NOT NULL,
    FOREIGN KEY (teacher_id)  REFERENCES Teacher(teacher_id)
        ON DELETE SET NULL,
    FOREIGN KEY (semester_id) REFERENCES Semester(semester_id)
        ON DELETE CASCADE
);

-- ── Enrollment ────────────────────────────────────────────────────
-- NOTE on FIX 9:
--   subject_id already encodes the semester (each Subject row belongs to
--   exactly one semester_id). Therefore UNIQUE(student_id, subject_id)
--   already prevents the same student from enrolling in the same subject
--   in the same semester twice, AND allows the same student to enroll in
--   a subject with the same name in a different semester (because that
--   will be a different subject_id). The original key is correct.
CREATE TABLE Enrollment (
    enrollment_id INT AUTO_INCREMENT PRIMARY KEY,
    student_id    INT NOT NULL,
    subject_id    INT NOT NULL,
    UNIQUE KEY uq_enrollment (student_id, subject_id),
    FOREIGN KEY (student_id) REFERENCES Student(student_id)
        ON DELETE CASCADE,
    FOREIGN KEY (subject_id) REFERENCES Subject(subject_id)
        ON DELETE CASCADE
);

-- ── Grades ────────────────────────────────────────────────────────
-- FIX 6: Grades stores ONLY the final computed percentage (0-100).
--   For detailed semesters: synced from GradeDetail when final_exam is entered.
--   For historical semesters: entered directly as a simple mark.
--   mark is DECIMAL to hold percentage values like 87.5.
CREATE TABLE Grades (
    grade_id    INT AUTO_INCREMENT PRIMARY KEY,
    student_id  INT NOT NULL,
    subject_id  INT NOT NULL,
    semester_id INT NOT NULL,
    mark        DECIMAL(5,2) CHECK (mark BETWEEN 0 AND 100),
    status      VARCHAR(10),
    UNIQUE KEY uq_grade (student_id, subject_id, semester_id),
    FOREIGN KEY (student_id)  REFERENCES Student(student_id)
        ON DELETE CASCADE,
    FOREIGN KEY (subject_id)  REFERENCES Subject(subject_id)
        ON DELETE CASCADE,
    FOREIGN KEY (semester_id) REFERENCES Semester(semester_id)
        ON DELETE CASCADE
);

-- ── GradeDetail ───────────────────────────────────────────────────
-- FIX 4: total is stored (computed) but protected by CHECK constraints.
--   Logic layer recomputes it every save so it stays in sync.
-- FIX 5: CHECK constraints enforce max per component.
-- Weights: quiz1(10) + quiz2(10) + midterm(20) + final(60) = 100 raw → /100 pct
CREATE TABLE GradeDetail (
    detail_id   INT AUTO_INCREMENT PRIMARY KEY,
    student_id  INT NOT NULL,
    subject_id  INT NOT NULL,
    semester_id INT NOT NULL,
    quiz1       DECIMAL(5,2) NULL CHECK (quiz1    IS NULL OR (quiz1    >= 0 AND quiz1    <= 10)),
    quiz2       DECIMAL(5,2) NULL CHECK (quiz2    IS NULL OR (quiz2    >= 0 AND quiz2    <= 10)),
    midterm     DECIMAL(5,2) NULL CHECK (midterm  IS NULL OR (midterm  >= 0 AND midterm  <= 20)),
    final_exam  DECIMAL(5,2) NULL CHECK (final_exam IS NULL OR (final_exam >= 0 AND final_exam <= 60)),
    total       DECIMAL(5,2) NULL CHECK (total    IS NULL OR (total    >= 0 AND total    <= 100)),
    UNIQUE KEY uq_detail (student_id, subject_id, semester_id),
    FOREIGN KEY (student_id)  REFERENCES Student(student_id)  ON DELETE CASCADE,
    FOREIGN KEY (subject_id)  REFERENCES Subject(subject_id)  ON DELETE CASCADE,
    FOREIGN KEY (semester_id) REFERENCES Semester(semester_id) ON DELETE CASCADE
);

-- ── SubjectResult ─────────────────────────────────────────────────
-- FIX 10 (bonus): stores end-of-year per-subject outcome
CREATE TABLE SubjectResult (
    result_id    INT AUTO_INCREMENT PRIMARY KEY,
    student_id   INT NOT NULL,
    subject_id   INT NOT NULL,
    semester_id  INT NOT NULL,
    total_mark   DECIMAL(5,2) NOT NULL,
    letter_grade VARCHAR(2)   NOT NULL,
    passed       TINYINT(1)   NOT NULL DEFAULT 0,
    UNIQUE KEY uq_result (student_id, subject_id, semester_id),
    FOREIGN KEY (student_id)  REFERENCES Student(student_id)  ON DELETE CASCADE,
    FOREIGN KEY (subject_id)  REFERENCES Subject(subject_id)  ON DELETE CASCADE,
    FOREIGN KEY (semester_id) REFERENCES Semester(semester_id) ON DELETE CASCADE
);

-- ── Attendance ────────────────────────────────────────────────────
CREATE TABLE Attendance (
    attendance_id INT AUTO_INCREMENT PRIMARY KEY,
    student_id    INT  NOT NULL,
    date          DATE NOT NULL,
    status        VARCHAR(10) NOT NULL,
    semester_id   INT NOT NULL,
    UNIQUE KEY uq_attendance (student_id, date),
    FOREIGN KEY (student_id)  REFERENCES Student(student_id)  ON DELETE CASCADE,
    FOREIGN KEY (semester_id) REFERENCES Semester(semester_id) ON DELETE CASCADE
);

-- ── GPA ───────────────────────────────────────────────────────────
CREATE TABLE GPA (
    gpa_id         INT AUTO_INCREMENT PRIMARY KEY,
    student_id     INT NOT NULL,
    school_year_id INT NOT NULL,
    value          DECIMAL(3,2) CHECK (value BETWEEN 0.00 AND 4.00),
    student_rank   INT,
    UNIQUE KEY uq_gpa (student_id, school_year_id),
    FOREIGN KEY (student_id)     REFERENCES Student(student_id)     ON DELETE CASCADE,
    FOREIGN KEY (school_year_id) REFERENCES AcademicYear(school_year_id) ON DELETE CASCADE
);

-- ── User ──────────────────────────────────────────────────────────
CREATE TABLE User (
    user_id        INT AUTO_INCREMENT PRIMARY KEY,
    user_name      VARCHAR(50)  NOT NULL UNIQUE,
    password       VARCHAR(255) NOT NULL,
    plain_password VARCHAR(100) NULL,           -- admin-only credential view
    role           VARCHAR(20)  NOT NULL,
    student_id     INT NULL,
    teacher_id     INT NULL,
    FOREIGN KEY (student_id) REFERENCES Student(student_id)  ON DELETE CASCADE,
    FOREIGN KEY (teacher_id) REFERENCES Teacher(teacher_id)  ON DELETE CASCADE
);

-- ── Announcement ─────────────────────────────────────────────────
-- FIX 8: table was missing
CREATE TABLE Announcement (
    announcement_id INT AUTO_INCREMENT PRIMARY KEY,
    sender_id       INT NOT NULL,
    title           VARCHAR(200) NOT NULL,
    body            TEXT NOT NULL,
    target_type     VARCHAR(20) NOT NULL,   -- 'all','students','teachers','class','student'
    target_id       INT NULL,               -- class_id or student_id when targeted
    created_at      DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (sender_id) REFERENCES User(user_id) ON DELETE CASCADE
);

-- ── AnnouncementRead ─────────────────────────────────────────────
CREATE TABLE AnnouncementRead (
    id              INT AUTO_INCREMENT PRIMARY KEY,
    announcement_id INT NOT NULL,
    user_id         INT NOT NULL,
    read_at         DATETIME DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uq_read (announcement_id, user_id),
    FOREIGN KEY (announcement_id) REFERENCES Announcement(announcement_id) ON DELETE CASCADE,
    FOREIGN KEY (user_id)         REFERENCES User(user_id)                  ON DELETE CASCADE
);


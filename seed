# Each student gets a realistic profile: base ability, trend, noise, subject biases.
# Trends are distributed realistically: ~40% improving, ~35% stable, ~25% declining.
print("Building student performance profiles...")
student_profile = {}
subject_biases  = {}   # per-student per-subject consistent bias

for s_id in student_ids:
    base  = random.uniform(35, 97)   # core ability across subjects

    # Realistic trend distribution
    r = random.random()
    if r < 0.25:
        trend = random.uniform(-3.5, -0.5)   # declining (~25%)
    elif r < 0.60:
        trend = random.uniform(-0.3, 0.3)    # stable (~35%)
    else:
        trend = random.uniform(0.5, 3.0)     # improving (~40%)

    noise = random.uniform(3, 10)    # semester-to-semester variability
    student_profile[s_id] = (base, trend, noise)

    # Each student has fixed strong/weak subjects (consistent across semesters)
    subject_biases[s_id] = {
        subj: random.gauss(0, 8) for subj in [
            "Mathematics","Science","English","Arabic","History",
            "Geography","Computer Science","Art","Physical Education","Economics"
        ]
    }

def student_mark(s_id, sem_idx, subj_name):
    """Generate a realistic mark that stays consistent per student across semesters."""
    base, trend, noise = student_profile[s_id]
    # Core trajectory
    adjusted = base + trend * sem_idx
    # Semester noise (good days / bad days)
    adjusted += random.uniform(-noise, noise)
    # Consistent subject strength/weakness
    bias = subject_biases[s_id].get(subj_name, 0)
    mark = max(2, min(100, adjusted + bias))
    return round(mark, 1)

def component_from_total(total, max_q1, max_q2, max_mid, max_fn):
    """Split a total mark into realistic component scores."""
    # Proportional split with small noise per component
    def noisy(prop, max_val):
        v = total * prop + random.uniform(-max_val*0.08, max_val*0.08)
        return round(max(0, min(max_val, v)), 1)
    q1 = noisy(max_q1  / 100, max_q1)
    q2 = noisy(max_q2  / 100, max_q2)
    mt = noisy(max_mid / 100, max_mid)
    fn = noisy(max_fn  / 100, max_fn)
    return q1, q2, mt, fn


def school_days(start, count):
    days, d = [], start
    while len(days) < count:
        if d.weekday() < 5: days.append(d)
        d += timedelta(days=1)
    return days

year_starts = {
    year_ids[0]: (date(2020,9,1),  date(2021,1,20)),
    year_ids[1]: (date(2021,9,1),  date(2022,1,20)),
    year_ids[2]: (date(2022,9,1),  date(2023,1,20)),
    year_ids[3]: (date(2023,9,1),  date(2024,1,20)),
    year_ids[4]: (date(2024,9,1),  date(2025,1,20)),
    year_ids[5]: (date(2025,9,1),  date(2026,1,20)),
}
# Attendance correlated with student ability — weaker students miss more
def make_att_pool(base_ability):
    """Return a status pool biased by student ability (0-100)."""
    # High ability → more present; Low ability → more absent
    present_w = int(60 + base_ability * 0.3)   # 60-90 range
    absent_w  = int(25 - base_ability * 0.15)  # 10-25 range
    late_w    = random.randint(3, 8)
    excused_w = random.randint(2, 6)
    return (["Present"] * present_w +
            ["Absent"]  * max(absent_w, 3) +
            ["Late"]    * late_w +
            ["Excused"] * excused_w)

att_rows = []
for s_id in student_ids:
    base_ability = student_profile[s_id][0]   # use student's base grade ability
    pool = make_att_pool(base_ability)
    start_idx = student_enroll_idx[s_id]
    for y_id in year_ids[start_idx:]:
        fall_start, spring_start = year_starts[y_id]
        if y_id == year_ids[5]:
            fall_days   = school_days(fall_start,   55)
            spring_days = school_days(spring_start, 40)
        else:
            fall_days   = school_days(fall_start,   55)
            spring_days = school_days(spring_start, 55)
        f_sem = semesters[(y_id,"Fall")]
        s_sem = semesters[(y_id,"Spring")]
        for day in fall_days:
            att_rows.append((s_id, day, random.choice(pool), f_sem))
        for day in spring_days:
            att_rows.append((s_id, day, random.choice(pool), s_sem))

for i in range(0, len(att_rows), chunk):
    cur.executemany("""INSERT IGNORE INTO Attendance
        (student_id,date,status,semester_id) VALUES (%s,%s,%s,%s)""",
        att_rows[i:i+chunk])

# ── GPA (years 2020-2024 only) ────────────────────────────────────
conn.commit()
print("GPA...")
gpa_rows = []
for y_id in year_ids[:-1]:
    avgs = []
    for s_id in student_ids:
        start_idx = student_enroll_idx[s_id]
        if year_ids.index(y_id) < start_idx: continue
        c_id  = student_class_map[s_id]
        grade = next(c[1] for c in classes if c[0]==c_id)
        marks = []
        for sem_name in ["Fall","Spring"]:
            sem_id = semesters[(y_id, sem_name)]
            for subj_name in grade_subjects[grade]:
                if subj_name == "Physical Education": continue
                sub_id = subject_map.get((c_id, sem_id, subj_name))
                if sub_id:
                    row = next((r for r in historical_grade_rows
                                if r[0]==s_id and r[1]==sub_id and r[2]==sem_id), None)
                    if row: marks.append(float(row[3]))
        if marks:
            gpa = round((sum(marks)/len(marks))/25, 2)
            avgs.append((s_id, gpa))
    by_class = defaultdict(list)
    for s_id, gpa in avgs:
        by_class[student_class_map[s_id]].append((s_id, gpa))
    for c_id, lst in by_class.items():
        lst.sort(key=lambda x: x[1], reverse=True)
        for rank, (s_id, gpa) in enumerate(lst, 1):
            gpa_rows.append((s_id, y_id, gpa, rank))

cur.executemany("""INSERT IGNORE INTO GPA
    (student_id,school_year_id,value,student_rank) VALUES (%s,%s,%s,%s)""", gpa_rows)

